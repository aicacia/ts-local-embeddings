{
	"name": "@aicacia/local-embeddings",
	"version": "0.1.0",
	"description": "local embeddings library",
	"repository": {
		"type": "git",
		"url": "https://github.com/aicacia/ts-local-embeddings"
	},
	"type": "module",
	"module": "./src/index.ts",
	"main": "./esm/index.js",
	"types": "./types/index.d.ts",
	"exports": {
		".": {
			"import": "./esm/index.js",
			"require": "./esm/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": ["esm/", "types/", "README.md", "LICENSE-MIT", "LICENSE-APACHE"],
	"scripts": {
		"tape:runner": "TS_NODE_TRANSPILE_ONLY=true node --import 'data:text/javascript,import { register } from \"node:module\"; import { pathToFileURL } from \"node:url\"; register(\"ts-node/esm\", pathToFileURL(\"./\"));' node_modules/tape/bin/tape",
		"build:ts": "tsc -p tsconfig.json",
		"build:browser": "rollup -c",
		"build:docs": "typedoc",
		"build": "pnpm run clean && pnpm run build:ts && pnpm run build:browser",
		"doc": "pnpm run build:docs",
		"prepublishOnly": "pnpm run build",
		"test": "pnpm run -s tape:runner -- src/**/*.test.{ts,tsx} | pnpm exec tap-spec",
		"coverage": "c8 --check-coverage --lines 75 --reporter=lcov --reporter=text pnpm run -s tape:runner -- src/**/*.test.{ts,tsx} | pnpm exec tap-spec",
		"coverageHTML": "c8 --check-coverage --lines 75 --reporter=lcov --reporter=html pnpm run -s tape:runner -- src/**/*.test.{ts,tsx} | pnpm exec tap-spec",
		"clean": "rm -rf esm browser dist types .nyc_output coverage",
		"lint": "biome lint ./src",
		"format": "biome format --write .",
		"format:check": "biome format --check .",
		"ci:lint": "pnpm lint && pnpm -r run lint",
		"ci:format": "pnpm format && pnpm -r run format",
		"ci:format:check": "pnpm -r run format:check",
		"playwright:install": "pnpm exec playwright install chromium",
		"playwright:test": "pnpm exec playwright test",
		"benchmark:dev": "vite",
		"benchmark": "pnpm run -s tape:runner -- tests/bench/benchmarks.test.ts | pnpm exec tap-spec",
		"benchmark:browser": "pnpm exec playwright test tests/playwright/benchmark.spec.ts --config=playwright.config.ts --reporter=list",
		"github-pages:dev": "pnpm --filter @aicacia/local-embeddings-github-pages dev",
		"preCommit": "pnpm run ci:format && pnpm run ci:lint && pnpm run coverage",
		"prepare": "husky install"
	},
	"keywords": [
		"local",
		"wasm",
		"embeddings",
		"browser",
		"similarity",
		"search",
		"vector",
		"database"
	],
	"author": "Nathan Faucett",
	"license": "(MIT OR Apache-2.0)",
	"readmeFilename": "README.md",
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@playwright/test": "^1.59.1",
		"@rollup/plugin-commonjs": "^28.0.9",
		"@rollup/plugin-node-resolve": "^15.3.1",
		"@rollup/plugin-terser": "^0.4.4",
		"@rollup/plugin-typescript": "^11.1.6",
		"@types/benchmark": "^2.1.5",
		"@types/tape": "^5.8.1",
		"benchmark": "^2.1.4",
		"c8": "^11.0.0",
		"fake-indexeddb": "^6.2.5",
		"husky": "^9.1.7",
		"lighthouse": "13.1.0",
		"lodash": "^4.18.1",
		"nyc": "^17.1.0",
		"platform": "^1.3.6",
		"rollup": "^4.60.2",
		"rollup-plugin-esm-import-to-url": "^2.1.0",
		"rollup-plugin-typescript2": "^0.37.0",
		"tap-nyc": "^1.0.3",
		"tap-spec": "^5.0.0",
		"tape": "^5.9.0",
		"ts-node": "^10.9.2",
		"tslib": "^2.8.1",
		"typedoc": "^0.28.19",
		"typescript": "^5.9.3",
		"vite": "^8.0.10"
	},
	"peerDependencies": {
		"tslib": "2"
	},
	"dependencies": {
		"@huggingface/transformers": "^4.2.0",
		"@langchain/core": "^1.1.41"
	},
	"nyc": {
		"include": ["src"],
		"exclude": ["src/**/*.test.*", "src/**/*.suite.*"],
		"extension": [".ts", ".tsx"]
	}
}
