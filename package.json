{
	"name": "@aicacia/local-embeddings",
	"version": "0.1.0",
	"description": "local embeddings library",
	"repository": {
		"type": "git",
		"url": "https://github.com/aicacia/ts-local-embeddings"
	},
	"type": "module",
	"module": "esm/index.js",
	"main": "esm/index.js",
	"types": "types/index.d.ts",
	"files": [
		"esm/",
		"types/",
		"browser/",
		"README.md",
		"LICENSE-MIT",
		"LICENSE-APACHE"
	],
	"scripts": {
		"buildTS": "tsc -p tsconfig.json",
		"buildBrowser": "rollup -c",
		"build:docs": "typedoc",
		"build": "npm run clean && npm run buildTS && npm run buildBrowser",
		"doc": "npm run build:docs",
		"prepublishOnly": "npm run build",
		"test": "node --loader ts-node/esm node_modules/tape/bin/tape src/**/*.test.{ts,tsx} | pnpm exec tap-spec",
		"bench": "node --loader ts-node/esm node_modules/tape/bin/tape src/**/*.benchmark.{ts,tsx} | pnpm exec tap-spec",
		"coverage": "c8 --check-coverage --lines 75 --reporter=lcov --reporter=text node --loader ts-node/esm node_modules/tape/bin/tape src/**/*.test.{ts,tsx} | pnpm exec tap-spec",
		"coverageHTML": "c8 --check-coverage --lines 75 --reporter=lcov --reporter=html node --loader ts-node/esm node_modules/tape/bin/tape src/**/*.test.{ts,tsx} | pnpm exec tap-spec",
		"clean": "rm -rf esm browser types .nyc_output coverage",
		"lint": "biome lint ./src",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"ci:lint": "pnpm -r lint",
		"ci:format": "pnpm -r format",
		"ci:format:check": "pnpm -r format:check",
		"github-pages:dev": "pnpm --filter @aicacia/local-embeddings-github-pages dev",
		"preCommit": "npm run ci:format && npm run ci:lint && npm run coverage",
		"prepare": "husky"
	},
	"keywords": [
		"local",
		"wasm",
		"embeddings",
		"browser",
		"similarity",
		"search",
		"vector",
		"database"
	],
	"author": "Nathan Faucett",
	"license": "(MIT OR Apache-2.0)",
	"readmeFilename": "README.md",
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@rollup/plugin-commonjs": "^28.0.9",
		"@rollup/plugin-node-resolve": "^15.3.1",
		"@rollup/plugin-terser": "^0.4.4",
		"@types/tape": "^5.8.1",
		"c8": "^11.0.0",
		"fake-indexeddb": "^6.2.5",
		"husky": "^9.1.7",
		"nyc": "^17.1.0",
		"rollup": "^4.60.1",
		"rollup-plugin-esm-import-to-url": "^2.1.0",
		"tap-nyc": "^1.0.3",
		"tap-spec": "^5.0.0",
		"tape": "^5.9.0",
		"ts-node": "^10.9.2",
		"tslib": "^2.8.1",
		"typedoc": "^0.28.18",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"tslib": "2"
	},
	"dependencies": {
		"@huggingface/transformers": "^4.0.1",
		"@langchain/core": "^1.1.39"
	},
	"nyc": {
		"include": ["src"],
		"exclude": ["src/**/*.test.*", "src/**/*.benchmark.*"],
		"extension": [".ts", ".tsx"]
	}
}
